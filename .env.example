# Message Broker
# Connection string for RabbitMQ
RABBITMQ_URL=

# API Server
# The port the Go receiver will listen on
PORT=

# GitHub Integration
# Personal Access Token with 'repo' scope to fetch logs, diffs, and post comments
GITHUB_TOKEN=
# Secret key used to verify HMAC SHA-256 signatures of incoming GitHub webhooks
GITHUB_WEBHOOK_SECRET=

# AI Configuration
# API key for Groq (Llama-3.1 models)
GROQ_API_KEY=

# Database Configuration (PostgreSQL + pgvector)
# Database administrative user
POSTGRES_USER=
# Database password
POSTGRES_PASSWORD=
# Name of the database for RAG storage
POSTGRES_DB=
# Full PostgreSQL connection string
DATABASE_URL=